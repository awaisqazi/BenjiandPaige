---
import Layout from '../layouts/Layout.astro';
import '../styles/main.css';
---

<Layout title="Paige & Benji | Save the Date | Campfires, S'mores & I Dos">

  <!-- ===== HERO SECTION ===== -->
  <section id="hero" class="hero">
    <div class="hero__video-wrap">
      <iframe
        id="hero-video"
        class="hero__video"
        src="https://www.youtube.com/embed/X2ShL6rGqBU?autoplay=1&mute=1&loop=1&playlist=X2ShL6rGqBU&controls=0&showinfo=0&modestbranding=1&playsinline=1&enablejsapi=1"
        title="Camp Getaway Video"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
      <div class="hero__overlay"></div>
    </div>

    <div class="hero__content">
      <h1 class="hero__names reveal reveal-delay-1">Paige <span class="hero__amp">&</span> Benji</h1>
      <p class="hero__tagline reveal reveal-delay-2">Campfires, S'mores & I Dos</p>
      <p class="hero__date reveal reveal-delay-3">October 4 – 5, 2026 &bull; Kent, Connecticut</p>
    </div>

    <a href="#postcard" class="hero__scroll-cta" aria-label="Scroll to next section">
      <span class="hero__scroll-text">Scroll to explore</span>
      <svg class="hero__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M19 12l-7 7-7-7"/>
      </svg>
    </a>

    <!-- Floating Sound Toggle -->
    <button id="soundToggle" class="hero__sound-btn" aria-label="Play with sound">
      <svg id="soundOffIcon" class="hero__sound-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
        <path d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/>
      </svg>
      <svg id="soundOnIcon" class="hero__sound-icon hero__sound-icon--hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
      </svg>
      <span id="soundText">Play with Sound</span>
    </button>
  </section>

  <!-- ===== POSTCARD / COUNTDOWN SECTION ===== -->
  <section id="postcard" class="postcard">
    <div class="postcard__bg">
      <img src="/images/campgetaway.png" alt="Greetings from Camp Getaway - P + B are getting married" loading="eager" />
    </div>

    <!-- Countdown: positioned bottom-right to avoid overlapping the letter -->
    <div class="postcard__countdown reveal">
      <div class="countdown" id="weddingCountdown">
        <div class="countdown__block">
          <span class="countdown__number" id="cdDays">---</span>
          <span class="countdown__label">DAYS</span>
        </div>
        <span class="countdown__sep">:</span>
        <div class="countdown__block">
          <span class="countdown__number" id="cdHours">--</span>
          <span class="countdown__label">HOURS</span>
        </div>
        <span class="countdown__sep">:</span>
        <div class="countdown__block">
          <span class="countdown__number" id="cdMins">--</span>
          <span class="countdown__label">MINS</span>
        </div>
        <span class="countdown__sep">:</span>
        <div class="countdown__block">
          <span class="countdown__number" id="cdSecs">--</span>
          <span class="countdown__label">SECS</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VENUE INFO SECTION ===== -->
  <section id="details" class="venue">
    <div class="venue__video-wrap">
      <video autoplay muted loop playsinline>
        <source src="/images/logistics.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="venue__overlay"></div>

    <div class="venue__content">
      <div class="venue__notebook reveal">
        <!-- Colorful film-strip tape across top -->
        <div class="venue__tape-strip" aria-hidden="true">
          <span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span>
        </div>

        <h2 class="venue__title">Venue Info</h2>

        <div class="venue__pin-row">
          <svg class="venue__pin-icon" viewBox="0 0 24 36" fill="none">
            <path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 24 12 24s12-15 12-24C24 5.4 18.6 0 12 0z" fill="#c0392b"/>
            <circle cx="12" cy="12" r="5" fill="#e74c3c"/>
            <circle cx="12" cy="12" r="2.5" fill="#c0392b"/>
          </svg>
          <div>
            <p class="venue__name">Club Getaway</p>
            <p class="venue__address">59 S Kent Rd, Kent, CT 06757</p>
          </div>
        </div>

        <div class="venue__map-wrap">
          <iframe
            class="venue__map"
            src="https://www.google.com/maps?q=Club+Getaway,+59+S+Kent+Rd,+Kent,+CT+06757&output=embed"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Club Getaway Map"
          ></iframe>
        </div>

        <a href="https://maps.google.com/?q=Club+Getaway+59+S+Kent+Rd+Kent+CT+06757" target="_blank" rel="noopener" class="venue__directions-link">
          Get Directions →
        </a>

        <!-- Camp Shuttle Info -->
        <div class="venue__shuttle">
          <div class="venue__shuttle-header">
            <span class="venue__shuttle-icon">🚐</span>
            <h3 class="venue__shuttle-title">Camp Shuttle</h3>
          </div>
          <p class="venue__shuttle-text">
            Taking the <strong>Metro North</strong> from Grand Central Station to <strong>Harlem Valley / Wingdale</strong>? A complimentary shuttle to Club Getaway is available!
          </p>
          <div class="venue__shuttle-steps">
            <div class="venue__shuttle-step">
              <span class="venue__shuttle-step-num">1</span>
              <p>Note your shuttle request in the comments section when you RSVP</p>
            </div>
            <div class="venue__shuttle-step">
              <span class="venue__shuttle-step-num">2</span>
              <p>Contact Club Getaway at <a href="tel:800-643-8292" class="venue__shuttle-phone">800-643-8292</a> at least <strong>2 weeks prior</strong> for train pickup times</p>
            </div>
          </div>
          <p class="venue__shuttle-note">⛺ Available on a first come, first served basis</p>
        </div>

        <!-- Parking Info -->
        <div class="venue__shuttle">
          <div class="venue__shuttle-header">
            <span class="venue__shuttle-icon">🅿️</span>
            <h3 class="venue__shuttle-title">Parking</h3>
          </div>
          <p class="venue__shuttle-text">
            Driving to the venue? <strong>Free parking</strong> is available on-site. Please plan to <strong>arrive at least 30 minutes early</strong> as you'll need to take a short shuttle from the parking area to the venue at the top of the hill.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SCHEDULE OF EVENTS SECTION ===== -->
  <section id="schedule" class="schedule">
    <h2 class="schedule__title reveal">Schedule of Events</h2>

    <div class="schedule__board reveal reveal-delay-1">
      <!-- Thumbtacks pinning the map to the corkboard -->
      <div class="schedule__pin schedule__pin--tl">
        <svg viewBox="0 0 40 50" width="28" height="35">
          <circle cx="20" cy="14" r="12" fill="#c0392b" stroke="#922b21" stroke-width="1.5"/>
          <ellipse cx="20" cy="14" rx="6" ry="4" fill="rgba(255,255,255,0.25)" transform="rotate(-30 20 14)"/>
          <path d="M20 26 L22 44 L20 50 L18 44 Z" fill="#888" stroke="#666" stroke-width="0.5"/>
        </svg>
      </div>
      <div class="schedule__pin schedule__pin--tr">
        <svg viewBox="0 0 40 50" width="28" height="35">
          <circle cx="20" cy="14" r="12" fill="#c0392b" stroke="#922b21" stroke-width="1.5"/>
          <ellipse cx="20" cy="14" rx="6" ry="4" fill="rgba(255,255,255,0.25)" transform="rotate(-30 20 14)"/>
          <path d="M20 26 L22 44 L20 50 L18 44 Z" fill="#888" stroke="#666" stroke-width="0.5"/>
        </svg>
      </div>
      <div class="schedule__pin schedule__pin--bl">
        <svg viewBox="0 0 40 50" width="24" height="30">
          <circle cx="20" cy="14" r="12" fill="#c0392b" stroke="#922b21" stroke-width="1.5"/>
          <ellipse cx="20" cy="14" rx="6" ry="4" fill="rgba(255,255,255,0.25)" transform="rotate(-30 20 14)"/>
          <path d="M20 26 L22 44 L20 50 L18 44 Z" fill="#888" stroke="#666" stroke-width="0.5"/>
        </svg>
      </div>
      <div class="schedule__pin schedule__pin--br">
        <svg viewBox="0 0 40 50" width="24" height="30">
          <circle cx="20" cy="14" r="12" fill="#c0392b" stroke="#922b21" stroke-width="1.5"/>
          <ellipse cx="20" cy="14" rx="6" ry="4" fill="rgba(255,255,255,0.25)" transform="rotate(-30 20 14)"/>
          <path d="M20 26 L22 44 L20 50 L18 44 Z" fill="#888" stroke="#666" stroke-width="0.5"/>
        </svg>
      </div>

      <div class="schedule__paper">
        <!-- Day 1 -->
        <h3 class="schedule__day-heading">Sunday, <span>October 4th</span></h3>

        <div class="schedule__grid schedule__grid--4col">
          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Cabin / Check-in -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- Roof -->
                <path d="M15 45L50 20L85 45" />
                <path d="M20 40L50 15L80 40" />
                <path d="M25 35L50 10L75 35" />
                <!-- Base -->
                <rect x="25" y="45" width="50" height="40" />
                <!-- Logs (horizontal lines) -->
                <path d="M25 55h50 M25 65h50 M25 75h50" />
                <!-- Log ends (circles on edges) -->
                <circle cx="21" cy="45" r="4"/><circle cx="79" cy="45" r="4"/>
                <circle cx="21" cy="55" r="4"/><circle cx="79" cy="55" r="4"/>
                <circle cx="21" cy="65" r="4"/><circle cx="79" cy="65" r="4"/>
                <circle cx="21" cy="75" r="4"/><circle cx="79" cy="75" r="4"/>
                <circle cx="21" cy="85" r="4"/><circle cx="79" cy="85" r="4"/>
                <!-- Door -->
                <path d="M42 85V60h16v25" />
                <circle cx="54" cy="72" r="1.5" />
              </svg>
            </div>
            <p class="schedule__event-name">Overnight Check-in</p>
            <p class="schedule__event-time">1:15 PM</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Ceremony (Refined) -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <!-- Groom Pants -->
                <path d="M38 60 L 35 85 L 42 85 L 43 70 L 45 85 L 50 85 L 50 60 Z" fill="var(--bark-dark)" />
                <!-- Groom Shoes -->
                <path d="M32 88 L 42 88 L 42 84 Z" fill="var(--bark-dark)" />
                <path d="M42 88 L 52 88 L 50 84 Z" fill="var(--bark-dark)" />
                <path d="M33 87 L 37 87 M43 87 L 47 87" stroke="var(--cream)" stroke-width="1" />
                <!-- Bride Dress -->
                <path d="M50 60 C 50 60 48 85 50 85 C 53 88 56 82 59 85 C 62 88 65 82 68 85 C 71 88 74 85 75 80 C 75 70 70 55 70 55" fill="var(--cream)" />
                <path d="M50 60 C 50 60 48 85 50 85 C 53 88 56 82 59 85 C 62 88 65 82 68 85 C 71 88 74 85 75 80 C 75 70 70 55 70 55" />
                <!-- Dress Pleats -->
                <path d="M58 70 L 59 80 M 64 70 L 66 80 M 70 70 L 72 78" stroke-width="1.5" />
                <!-- Bride Legs & Heels -->
                <path d="M58 85 L 56 93 M 65 85 L 63 93" stroke-width="1.5" />
                <path d="M53 93 L 57 93 L 57 90 Z M60 93 L 64 93 L 64 90 Z" fill="var(--bark-dark)" />
                <!-- Giant Heart -->
                <path d="M50 35 C 50 35 45 5 25 5 C 5 5 5 35 15 50 C 25 65 50 80 50 80 C 50 80 75 65 85 50 C 95 35 95 5 75 5 C 55 5 50 35 50 35 Z" fill="var(--cream)" />
                <path d="M50 35 C 50 35 45 5 25 5 C 5 5 5 35 15 50 C 25 65 50 80 50 80 C 50 80 75 65 85 50 C 95 35 95 5 75 5 C 55 5 50 35 50 35 Z" />
                <!-- Hands on Heart -->
                <path d="M12 40 C 9 39 9 44 12 44 C 10 45 10 49 13 48 C 12 50 14 52 16 50" stroke-width="1.5" />
                <path d="M88 40 C 91 39 91 44 88 44 C 90 45 90 49 87 48 C 88 50 86 52 84 50" stroke-width="1.5" />
              </svg>
            </div>
            <p class="schedule__event-name">Ceremony</p>
            <p class="schedule__event-time">2:00pm</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Margarita / Cocktail Hour -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- Glass Bowl -->
                <path d="M20 20 L80 20 C80 20 70 50 50 50 C30 50 20 20 20 20 Z" />
                <!-- Liquid line -->
                <path d="M26 30 Q50 35 72 30" stroke-width="1.5" stroke-dasharray="2 3"/>
                <!-- Stem -->
                <path d="M50 50 v30" />
                <circle cx="50" cy="65" r="4" />
                <!-- Base -->
                <path d="M35 80 Q50 75 65 80" />
                <!-- Lime Slice -->
                <circle cx="75" cy="20" r="12" />
                <path d="M75 20 l-8-8 M75 20 l8 8 M75 20 l8-8 M75 20 l-8 8" stroke-width="1.5"/>
              </svg>
            </div>
            <p class="schedule__event-name">Cocktail Hour</p>
            <p class="schedule__event-time">3:00pm</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Archery / Camp Activities -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- Target tripod -->
                <path d="M35 80 L50 60 L65 80 M50 60 V80" stroke-width="3" />
                <!-- Target rings -->
                <circle cx="50" cy="40" r="25" fill="var(--cream)" />
                <circle cx="50" cy="40" r="18" />
                <circle cx="50" cy="40" r="10" />
                <circle cx="50" cy="40" r="3" fill="var(--bark-dark)" />
                <!-- Arrows -->
                <path d="M50 40 L75 15" stroke-width="2" />
                <path d="M65 25 L75 15 L65 15" />
                <path d="M45 25 L80 10" stroke-width="1.5" />
              </svg>
            </div>
            <p class="schedule__event-name">Camp Activities Open</p>
            <p class="schedule__event-time">4:00PM</p>
          </div>
        </div>

        <div class="schedule__grid schedule__grid--4col">
          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Plate and Cutlery (Refined Minimal) -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <!-- Simple scalloped plate -->
                <path d="M50 15 C 60 15 65 20 70 25 C 75 30 80 40 80 50 C 80 60 75 70 70 75 C 65 80 60 85 50 85 C 40 85 35 80 30 75 C 25 70 20 60 20 50 C 20 40 25 30 30 25 C 35 20 40 15 50 15 Z" fill="var(--cream)" />
                <path d="M50 15 C 60 15 65 20 70 25 C 75 30 80 40 80 50 C 80 60 75 70 70 75 C 65 80 60 85 50 85 C 40 85 35 80 30 75 C 25 70 20 60 20 50 C 20 40 25 30 30 25 C 35 20 40 15 50 15 Z" />
                
                <!-- Inner plate ring -->
                <circle cx="50" cy="50" r="18" stroke-width="1.5" />
                <!-- Dotted detail -->
                <circle cx="50" cy="50" r="14" stroke-width="2" stroke-dasharray="0 4" />
                
                <!-- Scallop dividing lines -->
                <path d="M40 20 L 44 33 M 60 20 L 56 33 M 75 35 L 65 40 M 75 65 L 65 60 M 60 80 L 56 67 M 40 80 L 44 67 M 25 65 L 35 60 M 25 35 L 35 40" stroke-width="1.5" />
                
                <!-- Fork -->
                <path d="M11 25 V 40 M15 25 V 40 M19 25 V 40" stroke-width="1.5" />
                <path d="M11 38 C 11 45 19 45 19 38 M15 45 V 75" stroke-width="2" />
                
                <!-- Knife -->
                <path d="M85 20 V 45 C 82 45 82 40 82 30 C 82 20 85 20 85 20 Z" stroke-width="2" />
                <path d="M85 45 V 75" stroke-width="2" />
                
                <!-- Spoon -->
                <ellipse cx="94" cy="28" rx="4" ry="8" stroke-width="2" />
                <path d="M94 36 V 75" stroke-width="2" />
              </svg>
            </div>
            <p class="schedule__event-name">Dinner Reception</p>
            <p class="schedule__event-time">6:30PM</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Bonfire -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- Logs Base -->
                <path d="M25 80 L45 50 M75 80 L55 50 M35 85 L50 45 M65 85 L50 45" />
                <!-- Flames (pointy) -->
                <path d="M35 70 Q 30 50 40 35 Q 40 50 45 45 Q 50 20 60 30 Q 55 45 65 40 Q 60 55 70 65" stroke-linejoin="miter"/>
                <path d="M50 75 C30 75 25 50 35 40 C35 55 45 45 50 20 C55 45 65 55 65 40 C75 50 70 75 50 75 Z" fill="var(--cream)" />
                <path d="M50 75 C40 75 35 60 40 50 C40 60 45 55 50 35 C55 55 60 60 60 50 C65 60 60 75 50 75 Z" />
                <path d="M30 30 l2 2 M65 25 l3 -3 M55 10 l1 -2" stroke-width="2"/>
              </svg>
            </div>
            <p class="schedule__event-name">Bonfire</p>
            <p class="schedule__event-time">8:00pm</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Moon and Stars (Refined Minimal) -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <!-- Cleaner Crescent Moon -->
                <path d="M55 15 C 30 15 30 75 55 75 C 65 75 75 65 75 65 C 50 65 45 35 70 20 C 65 15 60 15 55 15 Z" fill="var(--cream)" />
                <path d="M55 15 C 30 15 30 75 55 75 C 65 75 75 65 75 65 C 50 65 45 35 70 20 C 65 15 60 15 55 15 Z" stroke-width="2.5" />
                
                <!-- 3 Simple Stars (Overlapping triangles for a sketch look, properly contained) -->
                <!-- Top Left Star -->
                <path d="M30 15 L35 30 L20 20 L40 20 L25 30 Z" stroke-width="1.5" />
                <!-- Bottom Left Star -->
                <path d="M15 45 L20 60 L10 50 L25 50 L10 60 Z" stroke-width="1.5" />
                <!-- Bottom Right Star -->
                <path d="M45 55 L50 70 L40 60 L55 60 L40 70 Z" stroke-width="1.5" />
              </svg>
            </div>
            <p class="schedule__event-name">Optional Overnight</p>
            <p class="schedule__event-time">9:30pm</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Disco ball / After Party -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- String -->
                <path d="M50 0 V30" />
                <path d="M45 30 h10 border-radius M48 30 v-5 M52 30v-5" />
                <!-- Ball -->
                <circle cx="50" cy="60" r="30" />
                <!-- Grid Lines -->
                <path d="M25 45 Q50 35 75 45 M21 55 Q50 45 79 55 M21 65 Q50 55 79 65 M25 75 Q50 65 75 75" stroke-width="1.5"/>
                <path d="M40 32 Q 30 60 40 88 M50 30 V 90 M60 32 Q 70 60 60 88" stroke-width="1.5"/>
              </svg>
            </div>
            <p class="schedule__event-name">After Party</p>
            <p class="schedule__event-time">10:00pm</p>
          </div>
        </div>

        <!-- Day 2 -->
        <h3 class="schedule__day-heading schedule__day-heading--day2">Monday, <span>October 5th</span></h3>

        <div class="schedule__grid schedule__grid--2col">
          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Coffee Cup / Breakfast -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <!-- Saucer -->
                <ellipse cx="50" cy="80" rx="30" ry="10" />
                <path d="M30 83 Q50 90 70 83" />
                <!-- Cup Base -->
                <path d="M25 45 C25 80, 75 80, 75 45 Z" fill="var(--cream)" />
                <!-- Cup Lip -->
                <ellipse cx="50" cy="45" rx="25" ry="8" fill="var(--cream)" />
                <ellipse cx="50" cy="45" rx="20" ry="5" />
                <!-- Handle -->
                <path d="M75 55 C90 55, 90 70, 70 70" />
                <!-- Steam -->
                <path d="M40 35 Q35 25 40 15 M50 35 Q45 25 50 15 M60 35 Q55 25 60 15" stroke-width="2" />
              </svg>
            </div>
            <p class="schedule__event-name">Breakfast</p>
            <p class="schedule__event-time">8:00am</p>
          </div>

          <div class="schedule__item">
            <div class="schedule__icon">
              <!-- Vintage Car / Check-out (Refined Minimal) -->
              <svg viewBox="0 0 100 100" fill="none" class="sketch-icon" stroke="var(--bark-dark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <!-- Car Roof & Windows -->
                <path d="M 30 35 C 30 15 70 15 70 35" fill="var(--cream)" />
                <path d="M 30 35 C 30 15 70 15 70 35" />
                <path d="M 35 35 C 40 22 60 22 65 35 Z" stroke-width="1.5" />
                
                <!-- Main Car Body (Beetle curve) -->
                <path d="M 15 55 C 10 35 30 35 50 35 C 70 35 90 35 85 55 C 80 70 70 65 50 65 C 30 65 20 70 15 55 Z" fill="var(--cream)" />
                <path d="M 15 55 C 10 35 30 35 50 35 C 70 35 90 35 85 55 C 80 70 70 65 50 65 C 30 65 20 70 15 55 Z" />
                
                <!-- Taillights -->
                <circle cx="22" cy="50" r="3" fill="var(--cream)" stroke-width="1.5" />
                <circle cx="78" cy="50" r="3" fill="var(--cream)" stroke-width="1.5" />
                
                <!-- Bumper -->
                <path d="M 15 62 Q 50 68 85 62" stroke-width="3" />
                <path d="M 30 58 V 65 M 70 58 V 65" stroke-width="2" />
                
                <!-- Tires -->
                <path d="M 22 64 C 20 78 32 78 30 64" fill="var(--bark-dark)" />
                <path d="M 78 64 C 80 78 68 78 70 64" fill="var(--bark-dark)" />
                
                <!-- "Just Married" Sign -->
                <rect x="25" y="42" width="50" height="12" rx="2" fill="var(--cream)" />
