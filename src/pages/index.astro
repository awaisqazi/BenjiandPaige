          <div class="footer__radio-group" id="colorWarsGroup">
            <label class="footer__radio-card footer__radio-card--sm">
              <input type="radio" name="entry.157830799" value="I'm in, let's go!" required />
              <span class="footer__radio-display">
                <span class="footer__radio-emoji">🏆</span>
                <span>I'm in, let's go!</span>
              </span>
            </label>
            <label class="footer__radio-card footer__radio-card--sm">
              <input type="radio" name="entry.157830799" value="I'll cheer from the sidelines" required />
              <span class="footer__radio-display">
                <span class="footer__radio-emoji">👀</span>
                <span>I'll cheer from the sidelines</span>
              </span>
            </label>
          </div>
          <span class="footer__error" id="colorWarsError">Please let us know if you're interested</span>
        </div>

        <!-- Comments -->
        <div class="footer__form-group">
          <label for="guestComments" class="footer__label-text">Comments <span class="footer__req">*</span></label>
          <textarea id="guestComments" name="entry.1599853593" placeholder="Anything else you'd like us to know? Special requests, plus-one info, song requests, etc." required rows="4"></textarea>
          <span class="footer__error" id="commentsError">Please add a comment or type "None"</span>
        </div>

        <!-- Honeypot Field (Hidden from humans) -->
        <div class="footer__honeypot" aria-hidden="true" style="position: absolute; left: -9999px; top: -9999px; width: 1px; height: 1px; overflow: hidden;">
          <label for="guestBait" class="footer__label-text">Leave this blank</label>
          <input type="text" id="guestBait" name="guest_bait_honey" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Human Verification (Anti-Bot) -->
        <div class="footer__form-group footer__captcha-group" id="captchaGroup">
          <label for="captchaAnswer" class="footer__label-text">
            Prove you're a happy camper: What is <span id="captchaQuestion" style="color: var(--fire-amber); font-weight: 700;"></span>? <span class="footer__req">*</span>
          </label>
          <input type="text" id="captchaAnswer" placeholder="Your answer" required autocomplete="off" />
          <span class="footer__error" id="captchaError">Please solve the riddle to prove you are a human</span>
        </div>

        <button type="submit" class="footer__submit" id="submitBtn">
          <span class="footer__submit-text">Send RSVP 🏕️</span>
        </button>
      </form>
      <iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>

      <!-- Confirmation toast -->
      <div class="footer__toast" id="confirmToast">
        <span class="footer__toast-icon">🎉</span>
        <span class="footer__toast-msg">RSVP received! See you at camp!</span>
      </div>

      <p class="footer__copyright">Paige & Benji · October 2026 · Made with 🤎 and campfire smoke</p>
    </div>
  </footer>

</Layout>

<script>
  // ===== Live Countdown to October 4, 2026 at 2:00 PM ET =====
  (function countdownTimer() {
    // October 4, 2026, 2:00 PM ET = 18:00 UTC (ET is UTC-4 in October / EDT)
    const weddingDate = new Date('2026-10-04T18:00:00Z');
    const cdDays = document.getElementById('cdDays');
    const cdHours = document.getElementById('cdHours');
    const cdMins = document.getElementById('cdMins');
    const cdSecs = document.getElementById('cdSecs');

    function pad(n: number) { return n.toString().padStart(2, '0'); }

    function update() {
      const now = new Date();
      const diff = weddingDate.getTime() - now.getTime();

      if (diff <= 0) {
        if (cdDays) cdDays.textContent = '0';
        if (cdHours) cdHours.textContent = '00';
        if (cdMins) cdMins.textContent = '00';
        if (cdSecs) cdSecs.textContent = '00';
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const secs = Math.floor((diff % (1000 * 60)) / 1000);

      if (cdDays) cdDays.textContent = days.toString();
      if (cdHours) cdHours.textContent = pad(hours);
      if (cdMins) cdMins.textContent = pad(mins);
      if (cdSecs) cdSecs.textContent = pad(secs);
    }

    update();
    setInterval(update, 1000);
  })();
  // ===== Intersection Observer for scroll reveal =====
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    // Force hero elements visible immediately
    document.querySelectorAll('.hero .reveal').forEach((el) => {
      setTimeout(() => el.classList.add('visible'), 300);
    });

    // ===== Star field in footer =====
    const starsContainer = document.getElementById('starsCanvas');
    if (starsContainer) {
      for (let i = 0; i < 120; i++) {
        const star = document.createElement('div');
        star.style.cssText = `
          position:absolute;
          width:${Math.random() * 3 + 1}px;
          height:${Math.random() * 3 + 1}px;
          background:${Math.random() > 0.7 ? '#fdd835' : '#fffde7'};
          border-radius:50%;
          top:${Math.random() * 100}%;
          left:${Math.random() * 100}%;
          opacity:${Math.random() * 0.7 + 0.2};
          animation:twinkle ${Math.random() * 3 + 2}s infinite alternate;
        `;
        starsContainer.appendChild(star);
      }

      const style = document.createElement('style');
      style.textContent = `@keyframes twinkle{0%{opacity:0.2;transform:scale(1)}100%{opacity:1;transform:scale(1.3)}}`;
      document.head.appendChild(style);
    }

    // ===== Vibe Section: Outfit Cycling =====
    const outfits = [
      {
        badge: "Dress Code",
        icon: "👗",
        title: "Dress Code",
        desc: "Dress to impress, but maybe leave the bug spray as perfume at home. Think 'rustic chic meets ready for s'mores.'"
      },
      {
        badge: "Ecology Special",
        icon: "🦥",
        title: "Queens Zoo Uniform",
        desc: "Paige's coordination outfit. Optimal for spotting wild animals and wearing heavy bug spray."
      },
      {
        badge: "Theatre Blacks",
        icon: "🎭",
        title: "Rutgers Cabaret Costume",
        desc: "Avenue Q attire. Ideal for hiding in prop closets or avoiding Benji's antics."
      },
      {
        badge: "The Road Trip",
        icon: "🚗",
        title: "Connecticut GPS Edition",
        desc: "Benji: 'Absolutely, GPS says we're almost there!' GPS: 'Welcome to Connecticut!' Paige: 'That's 90 minutes outside of NYC!'"
      }
    ];

    let currentOutfitIndex = 0;
    const outfitBadge = document.getElementById('outfitBadge');
    const outfitIcon = document.getElementById('outfitIcon');
    const outfitTitle = document.getElementById('outfitTitle');
    const outfitDesc = document.getElementById('outfitDesc');
    const outfitCycleBtn = document.getElementById('outfitCycleBtn');

    if (outfitCycleBtn) {
      outfitCycleBtn.addEventListener('click', () => {
        currentOutfitIndex = (currentOutfitIndex + 1) % outfits.length;
        const currentOutfit = outfits[currentOutfitIndex];

        // Apply a quick elastic scale animation on click
        outfitCycleBtn.style.transform = 'scale(0.8) rotate(-15deg)';
        setTimeout(() => {
          outfitCycleBtn.style.transform = '';
        }, 150);

        if (outfitBadge) outfitBadge.textContent = currentOutfit.badge;
        if (outfitIcon) outfitIcon.textContent = currentOutfit.icon;
        if (outfitTitle) outfitTitle.textContent = currentOutfit.title;
        if (outfitDesc) outfitDesc.innerHTML = currentOutfit.desc;
      });
    }

    // ===== Vibe Section: Cabin Night Mode Toggle =====
    const cabinNightBtn = document.getElementById('cabinNightBtn');
    const campPassCard = document.getElementById('campPassCard');

    if (cabinNightBtn && campPassCard) {
      cabinNightBtn.addEventListener('click', () => {
        campPassCard.classList.toggle('vibe__card--pass-night');

        // Animation bounce effect on click
        cabinNightBtn.style.transform = 'scale(0.8) rotate(15deg)';
        setTimeout(() => {
          cabinNightBtn.style.transform = '';
        }, 150);
      });
    }

    // ===== Packing List Persistence & Reset =====
    const packingCheckboxes = document.querySelectorAll('.packing__checkbox') as NodeListOf<HTMLInputElement>;
    const resetChecklistBtn = document.getElementById('resetChecklistBtn');

    // Load states on bootup
    try {
      const savedPackingState = localStorage.getItem('grecco_packing_list');
      if (savedPackingState) {
        const checkedIndices = JSON.parse(savedPackingState) as number[];
        packingCheckboxes.forEach((checkbox, index) => {
          if (checkedIndices.includes(index)) {
            checkbox.checked = true;
            const span = checkbox.nextElementSibling as HTMLElement;
            if (span) {
              span.style.textDecoration = 'line-through';
              span.style.opacity = '0.45';
            }
          }
        });
      }
    } catch (err) {
      console.warn('LocalStorage packing list read failed:', err);
    }

    // Save states on change
    packingCheckboxes.forEach((checkbox, index) => {
      checkbox.addEventListener('change', () => {
        const span = checkbox.nextElementSibling as HTMLElement;
        if (span) {
          if (checkbox.checked) {
            span.style.textDecoration = 'line-through';
            span.style.opacity = '0.45';
          } else {
            span.style.textDecoration = '';
            span.style.opacity = '';
          }
        }

        const checkedIndices: number[] = [];
        packingCheckboxes.forEach((cb, idx) => {
          if (cb.checked) checkedIndices.push(idx);
        });
        try {
          localStorage.setItem('grecco_packing_list', JSON.stringify(checkedIndices));
        } catch (err) {
          console.warn('LocalStorage packing list write failed:', err);
        }
      });
    });

    // Reset checklist action
    if (resetChecklistBtn) {
      resetChecklistBtn.addEventListener('click', (e) => {
        e.preventDefault();
        packingCheckboxes.forEach((checkbox) => {
          checkbox.checked = false;
          const span = checkbox.nextElementSibling as HTMLElement;
          if (span) {
            span.style.textDecoration = '';
            span.style.opacity = '';
          }
        });
        try {
          localStorage.removeItem('grecco_packing_list');
        } catch (err) {
          console.warn('LocalStorage packing list remove failed:', err);
        }

        // Play visual pop click bounce animation
        resetChecklistBtn.style.transform = 'scale(0.9) rotate(-3deg)';
        setTimeout(() => {
          resetChecklistBtn.style.transform = '';
        }, 150);
      });
    }


    // ===== Vibe Section: Polaroid & FaceTime Call Easter Egg =====
    const squirrel = document.getElementById('squirrelEgg');
    const facetimeOverlay = document.getElementById('facetimeOverlay');
    const declineCallBtn = document.getElementById('declineCallBtn');
    const acceptCallBtn = document.getElementById('acceptCallBtn');
    const closeCallBtn = document.getElementById('closeCallBtn');
    const facetimeIncomingView = document.getElementById('facetimeIncomingView');
    const facetimeConnectedView = document.getElementById('facetimeConnectedView');
    const facetimeCard = document.getElementById('facetimeCard');

    if (squirrel && facetimeOverlay) {
      let clicks = 0;
      squirrel.addEventListener('click', () => {
        clicks++;
        squirrel.style.transform = `rotate(${clicks * 30}deg) scale(${1 + clicks * 0.05})`;

        if (clicks >= 3) {
          // Reset card positions and open FaceTime overlay
          clicks = 0;
          setTimeout(() => {
            squirrel.style.transform = '';
          }, 300);

          // Reset FaceTime state
          if (facetimeIncomingView) facetimeIncomingView.style.display = 'block';
          if (facetimeConnectedView) facetimeConnectedView.style.display = 'none';
          if (facetimeCard) facetimeCard.className = 'facetime-card';

          facetimeOverlay.classList.add('facetime-overlay--active');
        }
      });
    }

    // FaceTime decline calls
    if (declineCallBtn && facetimeOverlay) {
      declineCallBtn.addEventListener('click', () => {
        facetimeOverlay.classList.remove('facetime-overlay--active');
      });
    }

    // FaceTime accept call action
    if (acceptCallBtn && facetimeIncomingView && facetimeConnectedView && facetimeCard) {
      acceptCallBtn.addEventListener('click', () => {
        facetimeIncomingView.style.display = 'none';
        facetimeConnectedView.style.display = 'block';
        facetimeCard.classList.add('facetime-card--connected');
      });
    }

    // FaceTime close call action
    if (closeCallBtn && facetimeOverlay) {
      closeCallBtn.addEventListener('click', () => {
        facetimeOverlay.classList.remove('facetime-overlay--active');
      });
    }

    // ===== Awaits Easter Egg (5 taps) =====
    const awaitsTrigger = document.getElementById('awaitsEgg');
    const awaitsImg = document.getElementById('awaitsEggImg');
    const activitiesSection = document.getElementById('activities');
    if (awaitsTrigger && awaitsImg) {
      let awaitsTaps: number[] = [];
      let awaitsAnimating = false;

      awaitsTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (awaitsAnimating) return;

        const now = Date.now();
        awaitsTaps = awaitsTaps.filter(t => now - t < 1500);
        awaitsTaps.push(now);

        if (awaitsTaps.length >= 5) {
          awaitsAnimating = true;
          awaitsTaps = [];
          activitiesSection?.classList.add('activities--egg-active');
          awaitsImg.classList.add('awaits-egg-img--active');

          setTimeout(() => {
            awaitsImg.classList.remove('awaits-egg-img--active');
            activitiesSection?.classList.remove('activities--egg-active');
            awaitsAnimating = false;
          }, 4200);
        }
      });
    }

    // ===== YouTube Sound Toggle =====
    const heroIframe = document.getElementById('hero-video') as HTMLIFrameElement;
    const heroVideoWrap = document.querySelector('.hero__video-wrap') as HTMLElement;
    const heroContent = document.querySelector('.hero__content') as HTMLElement;
    const heroOverlay = document.querySelector('.hero__overlay') as HTMLElement;
    const heroScrollCta = document.querySelector('.hero__scroll-cta') as HTMLElement;
    const soundToggle = document.getElementById('soundToggle');
    const soundOffIcon = document.getElementById('soundOffIcon');
    const soundOnIcon = document.getElementById('soundOnIcon');
    const soundTextEl = document.getElementById('soundText');
    let videoIsMuted = true;

    function enterWatchMode() {
      // Fade out overlay, content, scroll CTA
      heroContent?.classList.add('hero__content--hidden');
      heroOverlay?.classList.add('hero__overlay--hidden');
      heroScrollCta?.classList.add('hero__scroll-cta--hidden');

      // Switch iframe to contained mode with controls
      if (heroIframe) {
        heroIframe.classList.add('hero__video--contained');
        let newSrc = heroIframe.src
          .replace('controls=0', 'controls=1')
          .replace('mute=1', 'mute=0');
        heroIframe.src = newSrc;
      }
      if (heroVideoWrap) {
        heroVideoWrap.classList.add('hero__video-wrap--watch');
      }
    }

    function exitWatchMode() {
      // Restore overlays
      heroContent?.classList.remove('hero__content--hidden');
      heroOverlay?.classList.remove('hero__overlay--hidden');
      heroScrollCta?.classList.remove('hero__scroll-cta--hidden');

      // Restore iframe to cover mode without controls
      if (heroIframe) {
        heroIframe.classList.remove('hero__video--contained');
        let newSrc = heroIframe.src
          .replace('controls=1', 'controls=0')
          .replace('mute=0', 'mute=1');
        heroIframe.src = newSrc;
      }
      if (heroVideoWrap) {
        heroVideoWrap.classList.remove('hero__video-wrap--watch');
      }
    }

    soundToggle?.addEventListener('click', () => {
      if (videoIsMuted) {
        videoIsMuted = false;
        soundOffIcon?.classList.add('hero__sound-icon--hidden');
        soundOnIcon?.classList.remove('hero__sound-icon--hidden');
        if (soundTextEl) soundTextEl.textContent = 'Back to Save the Date';
        soundToggle.classList.add('hero__sound-btn--active');
        enterWatchMode();
      } else {
        videoIsMuted = true;
        soundOffIcon?.classList.remove('hero__sound-icon--hidden');
        soundOnIcon?.classList.add('hero__sound-icon--hidden');
        if (soundTextEl) soundTextEl.textContent = 'Play with Sound';
        soundToggle.classList.remove('hero__sound-btn--active');
        exitWatchMode();
      }
    });

    // ===== RSVP Form handling =====
    const form = document.getElementById('rosterForm') as HTMLFormElement;
    const firstNameInput = document.getElementById('guestFirstName') as HTMLInputElement;
    const lastNameInput = document.getElementById('guestLastName') as HTMLInputElement;
    const emailInput = document.getElementById('guestEmail') as HTMLInputElement;
    const phoneInput = document.getElementById('guestPhone') as HTMLInputElement;
    const addressInput = document.getElementById('guestAddress') as HTMLInputElement;
    const dietInput = document.getElementById('guestDiet') as HTMLInputElement;
    const commentsInput = document.getElementById('guestComments') as HTMLTextAreaElement;

    // Honeypot & Captcha inputs
    const honeypotInput = document.getElementById('guestBait') as HTMLInputElement;
    const captchaAnswerInput = document.getElementById('captchaAnswer') as HTMLInputElement;
    const captchaQuestion = document.getElementById('captchaQuestion');

    const firstNameError = document.getElementById('firstNameError');
    const lastNameError = document.getElementById('lastNameError');
    const emailError = document.getElementById('emailError');
    const phoneError = document.getElementById('phoneError');
    const addressError = document.getElementById('addressError');
    const dietError = document.getElementById('dietError');
    const attendingError = document.getElementById('attendingError');
    const overnightError = document.getElementById('overnightError');
    const shuttleError = document.getElementById('shuttleError');
    const colorWarsError = document.getElementById('colorWarsError');
    const commentsError = document.getElementById('commentsError');
    const captchaError = document.getElementById('captchaError');

    const attendingGroup = document.getElementById('attendingGroup');
    const overnightGroup = document.getElementById('overnightGroup');
    const shuttleGroup = document.getElementById('shuttleGroup');
    const colorWarsGroup = document.getElementById('colorWarsGroup');
    const captchaGroup = document.getElementById('captchaGroup');
    const toast = document.getElementById('confirmToast');

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    // ===== Dynamic Captcha Logic =====
    let captchaNum1 = 0;
    let captchaNum2 = 0;
    let captchaCorrectAnswer = 0;

    function generateCaptcha() {
      captchaNum1 = Math.floor(Math.random() * 9) + 1; // 1 to 9
      captchaNum2 = Math.floor(Math.random() * 9) + 1; // 1 to 9
      captchaCorrectAnswer = captchaNum1 + captchaNum2;
      if (captchaQuestion) {
        captchaQuestion.textContent = `${captchaNum1} + ${captchaNum2}`;
      }
      if (captchaAnswerInput) {
        captchaAnswerInput.value = '';
      }
    }

    generateCaptcha();

    // Helper: clear error on radio group selection
    function setupRadioClear(name: string, group: HTMLElement | null, error: HTMLElement | null) {
      document.querySelectorAll(`input[name="${name}"]`).forEach((radio) => {
        radio.addEventListener('change', () => {
          group?.classList.remove('input--error');
          error?.classList.remove('visible');
        });
      });
    }

    setupRadioClear('entry.1747976834', attendingGroup, attendingError);
    setupRadioClear('entry.1379738470', overnightGroup, overnightError);
    setupRadioClear('entry.1513616992', shuttleGroup, shuttleError);
    setupRadioClear('entry.157830799', colorWarsGroup, colorWarsError);

    // Helper: clear error on text/email/tel input
    function setupInputClear(input: HTMLInputElement | HTMLTextAreaElement | null, error: HTMLElement | null) {
      input?.addEventListener('input', () => {
        input.classList.remove('input--error');
        error?.classList.remove('visible');
      });
    }

    setupInputClear(firstNameInput, firstNameError);
    setupInputClear(lastNameInput, lastNameError);
    setupInputClear(emailInput, emailError);
    setupInputClear(phoneInput, phoneError);
    setupInputClear(addressInput, addressError);
    setupInputClear(dietInput, dietError);
    setupInputClear(commentsInput, commentsError);
    setupInputClear(captchaAnswerInput, captchaError);

    function clearAllErrors() {
      const inputs = [firstNameInput, lastNameInput, emailInput, phoneInput, addressInput, dietInput, commentsInput, captchaAnswerInput];
      const errors = [firstNameError, lastNameError, emailError, phoneError, addressError, dietError, attendingError, overnightError, shuttleError, colorWarsError, commentsError, captchaError];
      const groups = [attendingGroup, overnightGroup, shuttleGroup, colorWarsGroup, captchaGroup];
      inputs.forEach(i => i?.classList.remove('input--error'));
      errors.forEach(e => e?.classList.remove('visible'));
      groups.forEach(g => g?.classList.remove('input--error'));
    }

    function validateTextInput(input: HTMLInputElement | HTMLTextAreaElement | null, error: HTMLElement | null): boolean {
      if (!input?.value.trim()) {
        input?.classList.add('input--error');
        error?.classList.add('visible');
        return true;
      }
      return false;
    }

    function validateRadio(name: string, group: HTMLElement | null, error: HTMLElement | null): boolean {
      if (!document.querySelector(`input[name="${name}"]:checked`)) {
        group?.classList.add('input--error');
        error?.classList.add('visible');
        return true;
      }
      return false;
    }

    if (form) {
      form.addEventListener('submit', (e) => {
        clearAllErrors();
        let hasError = false;

        // Honeypot check: If the honeypot field is filled, we suspect a bot.
        // We prevent the actual submission to Google Forms but act as if it succeeded
        // to fool the bot into not retrying.
        if (honeypotInput && honeypotInput.value.trim() !== '') {
          e.preventDefault();
          
          const btn = document.getElementById('submitBtn') as HTMLButtonElement;
          if (btn) {
            btn.innerHTML = '<span>Sending… ✨</span>';
            btn.setAttribute('disabled', 'true');
          }

          setTimeout(() => {
            if (toast) {
              toast.classList.add('footer__toast--show');
            }
            if (btn) {
              btn.innerHTML = '<span class="footer__submit-text">Send RSVP 🏕️</span>';
              btn.removeAttribute('disabled');
            }
            form.reset();
            generateCaptcha();

            setTimeout(() => {
              toast?.classList.remove('footer__toast--show');
            }, 4000);
          }, 1200);

          return;
        }

        // Text fields
        if (validateTextInput(firstNameInput, firstNameError)) hasError = true;
        if (validateTextInput(lastNameInput, lastNameError)) hasError = true;

        // Email
        const emailVal = emailInput?.value.trim() || '';
        if (!emailVal || !emailRegex.test(emailVal)) {
          emailInput?.classList.add('input--error');
          emailError?.classList.add('visible');
          if (emailVal && !emailRegex.test(emailVal)) {
            if (emailError) emailError.textContent = 'That doesn\'t look like a valid email';
          } else {
            if (emailError) emailError.textContent = 'Please enter a valid email address';
          }
          hasError = true;
        }

        if (validateTextInput(phoneInput, phoneError)) hasError = true;
        if (validateTextInput(addressInput, addressError)) hasError = true;

        // Radio groups
        if (validateRadio('entry.1747976834', attendingGroup, attendingError)) hasError = true;

        if (validateTextInput(dietInput, dietError)) hasError = true;

        if (validateRadio('entry.1379738470', overnightGroup, overnightError)) hasError = true;
        if (validateRadio('entry.1513616992', shuttleGroup, shuttleError)) hasError = true;
        if (validateRadio('entry.157830799', colorWarsGroup, colorWarsError)) hasError = true;

        if (validateTextInput(commentsInput, commentsError)) hasError = true;

        // Captcha validation
        const captchaAnswerVal = captchaAnswerInput?.value.trim() || '';
        const captchaAnswerNum = parseInt(captchaAnswerVal, 10);
        if (isNaN(captchaAnswerNum) || captchaAnswerNum !== captchaCorrectAnswer) {
          captchaAnswerInput?.classList.add('input--error');
          captchaError?.classList.add('visible');
          if (captchaError) {
            if (!captchaAnswerVal) {
              captchaError.textContent = 'Please solve the riddle to prove you are a human';
            } else {
              captchaError.textContent = 'That math is a little off! Try again.';
            }
          }
          hasError = true;
        }

        if (hasError) {
          e.preventDefault();
          // Scroll to first error
          const firstError = form.querySelector('.input--error, .footer__error.visible');
          if (firstError) {
            firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return;
        }

        // Validation passed — allow native submit to hidden_iframe (Google Forms)
        const btn = document.getElementById('submitBtn') as HTMLButtonElement;
        if (btn) {
          btn.innerHTML = '<span>Sending… ✨</span>';
          btn.setAttribute('disabled', 'true');
        }

        // Show confirmation toast after a short delay
        setTimeout(() => {
          if (toast) {
            toast.classList.add('footer__toast--show');
          }
          if (btn) {
            btn.innerHTML = '<span class="footer__submit-text">Send RSVP 🏕️</span>';
            btn.style.background = '';
            btn.removeAttribute('disabled');
          }
          form.reset();
          generateCaptcha();

          // Auto-dismiss toast
          setTimeout(() => {
            toast?.classList.remove('footer__toast--show');
          }, 4000);
        }, 1200);
      });
    }
  });
</script>
